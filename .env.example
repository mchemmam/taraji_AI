# Taraji AI Environment Variables
# Copy this file to .env and fill in your actual values

# Telegram Configuration
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# Chat/channel that receives new articles (numeric chat id or @channelname).
# Run `python main.py telegram-setup` to discover chat ids.
# Switch this to the public channel (@taraji_news) at launch.
TELEGRAM_CHAT_ID=

# Facebook Page (Taraji Press) auto-posting.
# Run `python main.py facebook-setup` for the one-time token walkthrough.
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
# Only needed once, to generate the long-lived Page token above:
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_USER_TOKEN=

# Google Gemini API
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Database
DATABASE_PATH=data/taraji_ai.db

# Logging
LOG_LEVEL=INFO
