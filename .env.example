# Taraji AI Environment Variables
# Copy this file to .env and fill in your actual values

# Telegram Configuration
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# Chat/channel that receives new articles (numeric chat id or @channelname).
# Run `python main.py telegram-setup` to discover chat ids.
TELEGRAM_CHAT_ID=
# Public channel for the future official launch
TELEGRAM_CHANNEL_ID=@taraji_news

# Google Gemini API
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Database
DATABASE_PATH=data/taraji_ai.db

# Logging
LOG_LEVEL=INFO
